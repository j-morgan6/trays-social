<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Trays" suffix=" · Trays">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/x-icon" href={~p"/favicon.ico"} />
    <link rel="apple-touch-icon" href={~p"/apple-touch-icon.png"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&display=swap" rel="stylesheet" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="bg-base-200">
    <%!-- Editorial header — matches the WebHeader from the design handoff:
         serif Trays wordmark in primary green, three-tab nav (Feed / Find /
         My Tray) with a primary under-border on the active tab, search,
         amber New recipe pill, notification bell with amber unread dot,
         avatar dropdown. --%>
    <% nav_tab = assigns[:current_tab] %>
    <header class="sticky top-0 z-50 bg-base-100 border-b border-base-300">
      <div class="max-w-7xl mx-auto h-16 flex items-center px-6 md:px-8 gap-7">
        <.link href={~p"/"} class="font-serif-editorial text-primary text-[26px] leading-none">
          Trays
        </.link>

        <%!-- Primary nav: Feed / Find / My Tray --%>
        <nav class="hidden md:flex gap-6 ml-2">
          <.link
            href={~p"/"}
            class={[
              "text-sm py-[22px] border-b-2 transition-colors",
              if(nav_tab == :feed,
                do: "text-base-content font-semibold border-primary",
                else: "text-base-content/60 font-medium border-transparent hover:text-base-content"
              )
            ]}
          >
            Feed
          </.link>
          <.link
            href={~p"/explore"}
            class={[
              "text-sm py-[22px] border-b-2 transition-colors",
              if(nav_tab == :explore,
                do: "text-base-content font-semibold border-primary",
                else: "text-base-content/60 font-medium border-transparent hover:text-base-content"
              )
            ]}
          >
            Find
          </.link>
          <%= if @current_scope do %>
            <.link
              href={~p"/my-tray"}
              class={[
                "text-sm py-[22px] border-b-2 transition-colors",
                if(nav_tab == :my_tray,
                  do: "text-base-content font-semibold border-primary",
                  else: "text-base-content/60 font-medium border-transparent hover:text-base-content"
                )
              ]}
            >
              My Tray
            </.link>
          <% end %>
        </nav>

        <div class="flex-1"></div>

        <%!-- Quiet search field — links to Find. Mirrors the design's
             always-visible search pill in the WebHeader. --%>
        <.link
          href={~p"/explore"}
          class="hidden md:inline-flex items-center gap-2 h-9 w-[320px] px-3.5 rounded-full bg-base-200 border border-base-300 text-base-content/60 text-xs hover:text-base-content transition-colors"
        >
          <.icon name="hero-magnifying-glass" class="size-4" />
          <span>Search recipes, cooks, ingredients…</span>
        </.link>

        <%= if @current_scope do %>
          <%!-- Notifications bell with amber unread dot --%>
          <.link navigate={~p"/notifications"} class="relative p-1.5 text-base-content/70 hover:text-base-content transition-colors">
            <.icon name="hero-bell" class="size-5" />
            <%= if assigns[:unread_notifications] && assigns[:unread_notifications] > 0 do %>
              <span class="absolute top-0 right-0 w-2 h-2 rounded-full bg-accent"></span>
            <% end %>
          </.link>

          <%!-- Amber New recipe pill — Golden Amber is reserved for the
               create action; this is its primary use site on web. --%>
          <.link
            href={~p"/posts/new"}
            class="inline-flex items-center gap-1.5 h-9 px-4 rounded-md bg-accent text-accent-content text-xs font-semibold hover:brightness-95 transition"
          >
            <.icon name="hero-plus" class="size-4" />
            <span class="hidden sm:inline">New recipe</span>
          </.link>

          <%!-- Avatar dropdown — preserves existing menu --%>
          <div class="dropdown dropdown-end">
            <label tabindex="0" class="cursor-pointer">
              <.user_avatar
                username={@current_scope.user.username}
                photo_url={@current_scope.user.profile_photo_url}
                size="md"
              />
            </label>
            <ul
              tabindex="0"
              class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow-lg bg-base-100 rounded-box w-52 border border-base-300"
            >
              <li class="menu-title">
                <span class="text-base-content font-semibold">
                  @{@current_scope.user.username}
                </span>
              </li>
              <li>
                <.link href={~p"/@#{@current_scope.user.username}"}>Your Profile</.link>
              </li>
              <li>
                <.link href={~p"/users/settings"}>Settings</.link>
              </li>
              <div class="divider my-0"></div>
              <li>
                <.link href={~p"/users/log-out"} method="delete" class="text-error">
                  Log out
                </.link>
              </li>
            </ul>
          </div>
        <% else %>
          <.link href={~p"/users/log-in"} class="btn btn-ghost btn-sm">Log in</.link>
          <.link href={~p"/users/register"} class="btn btn-primary btn-sm">Sign up</.link>
        <% end %>
      </div>
    </header>

    <%!-- Email confirmation banner --%>
    <%= if @current_scope && is_nil(@current_scope.user.confirmed_at) do %>
      <div class="bg-warning/10 border-b border-warning/30 px-4 py-3">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-4 text-sm">
          <p class="text-warning-content">
            Please confirm your email address to post, comment, and interact with others.
            Check your inbox for the confirmation link.
          </p>
          <.link href={~p"/users/confirmation/resend"} method="post" class="btn btn-warning btn-xs shrink-0">
            Resend email
          </.link>
        </div>
      </div>
    <% end %>

    <%!-- Flash messages, rendered globally so controller flows (login,
         signup, settings, etc.) and LiveView flashes both surface
         without needing each page to wrap in a layout component. --%>
    <Layouts.flash_group flash={@flash} />

    <%!-- Main Content --%>
    <main class="min-h-screen py-8 pb-24 md:pb-8">
      {@inner_content}
    </main>

    <%!-- Mobile Bottom Tab Bar --%>
    <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-base-100 border-t border-base-300">
      <div class="flex items-center justify-around h-16">
        <%!-- Feed --%>
        <.link
          navigate={~p"/"}
          class={"flex flex-col items-center gap-0.5 px-4 py-2 text-xs font-medium transition-colors #{if assigns[:current_tab] == :feed, do: "text-primary", else: "text-base-content/50 hover:text-base-content"}"}
        >
          <span class="hero-home w-6 h-6"></span>
          <span>Feed</span>
        </.link>

        <%= if @current_scope do %>
          <%!-- Profile --%>
          <.link
            navigate={~p"/@#{@current_scope.user.username}"}
            class={"flex flex-col items-center gap-0.5 px-4 py-2 text-xs font-medium transition-colors #{if assigns[:current_tab] == :profile, do: "text-primary", else: "text-base-content/50 hover:text-base-content"}"}
          >
            <span class="hero-user w-6 h-6"></span>
            <span>Profile</span>
          </.link>

          <%!-- New Post (center-prominent) --%>
          <.link
            navigate={~p"/posts/new"}
            class={"flex flex-col items-center gap-0.5 px-4 py-2 text-xs font-medium transition-colors #{if assigns[:current_tab] == :new_post, do: "text-primary", else: "text-base-content/50 hover:text-base-content"}"}
          >
            <span class="hero-plus-circle w-7 h-7"></span>
            <span>Post</span>
          </.link>

          <%!-- Explore --%>
          <.link
            navigate={~p"/explore"}
            class={"flex flex-col items-center gap-0.5 px-4 py-2 text-xs font-medium transition-colors #{if assigns[:current_tab] == :explore, do: "text-primary", else: "text-base-content/50 hover:text-base-content"}"}
          >
            <span class="hero-magnifying-glass w-6 h-6"></span>
            <span>Explore</span>
          </.link>
        <% else %>
          <%!-- Feed (guest placeholder) --%>
          <.link
            navigate={~p"/users/log-in"}
            class="flex flex-col items-center gap-0.5 px-4 py-2 text-xs font-medium text-base-content/50 hover:text-base-content transition-colors"
          >
            <span class="hero-user w-6 h-6"></span>
            <span>Profile</span>
          </.link>

          <.link
            navigate={~p"/users/log-in"}
            class="flex flex-col items-center gap-0.5 px-4 py-2 text-xs font-medium text-base-content/50 hover:text-base-content transition-colors"
          >
            <span class="hero-plus-circle w-7 h-7"></span>
            <span>Post</span>
          </.link>

          <.link
            navigate={~p"/explore"}
            class={[
              "flex flex-col items-center gap-0.5 px-4 py-2 text-xs font-medium transition-colors",
              if(assigns[:current_tab] == :explore,
                do: "text-primary",
                else: "text-base-content/50 hover:text-base-content"
              )
            ]}
          >
            <span class="hero-magnifying-glass w-6 h-6"></span>
            <span>Explore</span>
          </.link>
        <% end %>
      </div>
    </nav>
  </body>
</html>
